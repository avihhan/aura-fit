# Flask API — desktop browser on same PC as `python run.py`
VITE_API_URL=http://localhost:5000

# Android emulator WebView: use host loopback (Flask on your machine)
# VITE_API_URL=http://10.0.2.2:5000

# Physical device on LAN: use your PC's IP (Flask must listen on 0.0.0.0)
# VITE_API_URL=http://192.168.1.x:5000

# Production / Cloud Run
# VITE_API_URL=https://your-api-xxxxx-xx.a.run.app

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — admin portal link from mobile web
# VITE_PORTAL_URL=http://localhost:3000
