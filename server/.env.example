FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=

PORT=5000

# Comma-separated extra browser origins for CORS (LAN IPs, Cloud Run frontends, production domains).
# Example: https://your-mobile-web.run.app,https://your-admin.run.app,http://192.168.1.10:3001
CORS_ORIGINS=
# Bucket used for tenant logos. For current logo_url flow, this bucket must allow public read.
SUPABASE_LOGO_BUCKET=tenant-branding

# Gemini AI planner
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Outbound email
# Option A: SendGrid
SENDGRID_API_KEY=
# Sender address used in weekly summaries (subject includes organization name)
SENDGRID_FROM_EMAIL=burnerwill111@gmail.com

# Option B: SMTP (used when SendGrid key is missing)
# For Gmail, use:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=burnerwill111@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=burnerwill111@gmail.com

# Lemon Squeezy billing (test keys initially)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_REDIRECT_URL=
